<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> – Portforaisa</title>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
  <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<!-- ═══════════════════════════════════════════════════
     SIDEBAR
═══════════════════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">

  <div class="sidebar-brand">
    <div class="brand-logo">
      <i class="bi bi-camera-video-fill"></i>
    </div>
    <div class="brand-text">
      <span class="brand-name">Portforaisa</span>
      <span class="brand-tagline">Porto for Raisa ✨</span>
    </div>
  </div>

  <nav class="sidebar-nav">
    <span class="nav-label">MENU</span>

    <a href="/" class="nav-link-item <%= title === 'Dashboard' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-grid-1x2-fill"></i></span>
      <span>Dashboard</span>
    </a>

    <a href="/konten" class="nav-link-item <%= title === 'Content Planner' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-collection-play-fill"></i></span>
      <span>Content Planner</span>
    </a>

    <a href="/konten/tambah" class="nav-link-item <%= (title === 'Tambah Konten' || title === 'Edit Konten') ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-plus-square-fill"></i></span>
      <span>Tambah Konten</span>
    </a>

    <span class="nav-label mt-3">STATUS</span>

    <div class="status-legend">
      <span class="sl-dot idea"></span><span>Idea</span>
      <span class="sl-dot shooting"></span><span>Shooting</span>
      <span class="sl-dot editing"></span><span>Editing</span>
      <span class="sl-dot ready"></span><span>Ready</span>
      <span class="sl-dot posted"></span><span>Posted</span>
    </div>
  </nav>

  <div class="sidebar-footer">
    <div class="sf-tiktok">
      <i class="bi bi-tiktok"></i>
      <div>
        <span class="sf-name">Portforaisa</span>
        <span class="sf-sub">TikTok Content Creator</span>
      </div>
    </div>
  </div>
</aside>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- ═══════════════════════════════════════════════════
     MAIN WRAPPER
═══════════════════════════════════════════════════ -->
<div class="main-wrapper" id="mainWrapper">

  <!-- TOPBAR -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="btn-hamburger" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
      </button>
      <div class="page-info">
        <h1 class="page-title"><%= title %></h1>
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <% if (title !== 'Dashboard') { %>
            <li class="breadcrumb-item active"><%= title %></li>
            <% } %>
          </ol>
        </nav>
      </div>
    </div>
    <div class="topbar-right">
      <div class="topbar-clock" id="topbarClock"></div>
    </div>
  </header>

  <!-- CONTENT -->
  <main class="content-main">
