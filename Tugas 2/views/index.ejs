<%- include('partials/header') %>

<!-- ═══ STAT CARDS ═══════════════════════════════════════ -->
<div class="row g-3 mb-4">

  <div class="col-6 col-xl-2">
    <div class="stat-card sc-total">
      <div class="sc-icon"><i class="bi bi-collection-play-fill"></i></div>
      <div class="sc-val"><%= stats.total %></div>
      <div class="sc-lbl">Total Konten</div>
    </div>
  </div>

  <div class="col-6 col-xl-2">
    <div class="stat-card sc-idea">
      <div class="sc-icon"><i class="bi bi-lightbulb-fill"></i></div>
      <div class="sc-val"><%= stats.idea %></div>
      <div class="sc-lbl">Idea</div>
    </div>
  </div>

  <div class="col-6 col-xl-2">
    <div class="stat-card sc-shooting">
      <div class="sc-icon"><i class="bi bi-camera-video-fill"></i></div>
      <div class="sc-val"><%= stats.shooting %></div>
      <div class="sc-lbl">Shooting</div>
    </div>
  </div>

  <div class="col-6 col-xl-2">
    <div class="stat-card sc-editing">
      <div class="sc-icon"><i class="bi bi-scissors"></i></div>
      <div class="sc-val"><%= stats.editing %></div>
      <div class="sc-lbl">Editing</div>
    </div>
  </div>

  <div class="col-6 col-xl-2">
    <div class="stat-card sc-ready">
      <div class="sc-icon"><i class="bi bi-check2-circle"></i></div>
      <div class="sc-val"><%= stats.ready %></div>
      <div class="sc-lbl">Ready</div>
    </div>
  </div>

  <div class="col-6 col-xl-2">
    <div class="stat-card sc-posted">
      <div class="sc-icon"><i class="bi bi-tiktok"></i></div>
      <div class="sc-val"><%= stats.posted %></div>
      <div class="sc-lbl">Posted</div>
    </div>
  </div>

</div>

<!-- ═══ UPCOMING + QUICK ADD ════════════════════════════ -->
<div class="row g-4">

  <!-- Upcoming Schedule -->
  <div class="col-xl-8">
    <div class="pf-card h-100">
      <div class="pf-card-head">
        <span><i class="bi bi-calendar2-week-fill me-2"></i>Jadwal Terdekat</span>
        <a href="/konten" class="btn-see-all">Lihat Semua <i class="bi bi-arrow-right"></i></a>
      </div>
      <div class="pf-card-body p-0">
        <% if (upcoming.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-calendar-x"></i>
            <p>Belum ada konten yang dijadwalkan.</p>
            <a href="/konten/tambah" class="btn btn-yellow rounded-pill px-4">
              <i class="bi bi-plus-lg me-1"></i> Tambah Sekarang
            </a>
          </div>
        <% } else { %>
          <div class="upcoming-list">
            <% upcoming.forEach(function(k, i) { %>
              <div class="upcoming-item">
                <div class="up-num"><%= i + 1 %></div>
                <div class="up-info">
                  <div class="up-judul"><%= k.judul %></div>
                  <div class="up-jadwal">
                    <i class="bi bi-clock me-1"></i>
                    <%= new Date(k.jadwal).toLocaleDateString('id-ID',{weekday:'short',day:'2-digit',month:'short',year:'numeric'}) %>
                    &nbsp;|&nbsp;
                    <%= new Date(k.jadwal).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) %> WIB
                  </div>
                </div>
                <% const statusClass = k.status.toLowerCase(); %>
                <span class="status-pill sp-<%= statusClass %>"><%= k.status %></span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="col-xl-4">
    <div class="pf-card h-100">
      <div class="pf-card-head">
        <span><i class="bi bi-lightning-fill me-2"></i>Aksi Cepat</span>
      </div>
      <div class="pf-card-body">
        <a href="/konten/tambah" class="quick-btn qb-yellow">
          <i class="bi bi-plus-square-fill"></i>
          <div>
            <strong>Tambah Konten Baru</strong>
            <span>Buat ide konten TikTok</span>
          </div>
        </a>
        <a href="/konten" class="quick-btn qb-dark">
          <i class="bi bi-collection-play-fill"></i>
          <div>
            <strong>Lihat Semua Konten</strong>
            <span>Kelola & update status</span>
          </div>
        </a>

        <!-- Progress Bar Status -->
        <div class="status-progress mt-4">
          <div class="sp-label">
            <span>Pipeline Progress</span>
            <% const pct = stats.total > 0 ? Math.round((stats.posted / stats.total) * 100) : 0 %>
            <span><%= pct %>% Posted</span>
          </div>
          <div class="progress" style="height:8px;border-radius:99px;">
            <div class="progress-bar bg-yellow" role="progressbar"
              style="width:<%= pct %>%" aria-valuenow="<%= pct %>"
              aria-valuemin="0" aria-valuemax="100"></div>
          </div>
        </div>

      </div>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
